#!/bin/sh
# Hook pre-push o13sLife
# Activer avec : git config core.hooksPath .githooks

echo "[pre-push] Lancement de la suite de tests complète..."

echo "[pre-push] Tests Pest..."
php8.3 vendor/bin/pest
if [ $? -ne 0 ]; then
  echo "[pre-push] ❌ Les tests échouent. Push annulé."
  exit 1
fi

if find tests/e2e -name "*.spec.*" 2>/dev/null | grep -q .; then
  echo "[pre-push] Tests E2E Playwright..."
  npx playwright test
  if [ $? -ne 0 ]; then
    echo "[pre-push] ❌ Les tests E2E échouent. Push annulé."
    exit 1
  fi
else
  echo "[pre-push] ⏭️  Aucun test E2E trouvé — Playwright ignoré."
fi

echo "[pre-push] ✅ Tous les tests sont passés. Push autorisé."
exit 0
