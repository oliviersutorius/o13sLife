#!/bin/sh
# Hook pre-commit o13sLife
# Activer avec : git config core.hooksPath .githooks

echo "[pre-commit] Vérification du formatage PHP (Pint)..."
php8.3 vendor/bin/pint --test
if [ $? -ne 0 ]; then
  echo "[pre-commit] ❌ Le formatage échoue. Lance ./vendor/bin/pint pour corriger."
  exit 1
fi

echo "[pre-commit] Vérification des instructions de debug oubliées..."
if grep -rn --include="*.php" -E "(dd\(|var_dump\(|dump\()" app/ resources/ 2>/dev/null | grep -v "vendor/"; then
  echo "[pre-commit] ❌ Des instructions de debug (dd, var_dump, dump) sont présentes dans le code."
  exit 1
fi

echo "[pre-commit] ✅ Toutes les vérifications sont passées."
exit 0
